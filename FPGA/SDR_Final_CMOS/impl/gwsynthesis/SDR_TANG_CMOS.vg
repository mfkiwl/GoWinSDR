module GMII2RGMII (
  RGMII_GTXCLK_d,
  gmii_txd_r,
  RGMII_TXD_d
)
;
input RGMII_GTXCLK_d;
input [7:0] gmii_txd_r;
output [3:0] RGMII_TXD_d;
wire \oddr_gen[0].oddr_inst_1_Q1 ;
wire \oddr_gen[1].oddr_inst_1_Q1 ;
wire \oddr_gen[2].oddr_inst_1_Q1 ;
wire \oddr_gen[3].oddr_inst_1_Q1 ;
