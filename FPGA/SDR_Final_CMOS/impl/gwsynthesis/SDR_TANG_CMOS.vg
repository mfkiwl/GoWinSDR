wire GND;
  ODDR \oddr_gen[0].oddr_inst  (
    .Q0(RGMII_TXD_d[0]),
    .Q1(\oddr_gen[0].oddr_inst_1_Q1 ),
    .D0(gmii_txd_r[0]),
    .D1(gmii_txd_r[4]),
    .TX(GND),
    .CLK(RGMII_GTXCLK_d) 
);
  ODDR \oddr_gen[1].oddr_inst  (
    .Q0(RGMII_TXD_d[1]),
    .Q1(\oddr_gen[1].oddr_inst_1_Q1 ),
    .D0(gmii_txd_r[1]),
    .D1(gmii_txd_r[5]),
    .TX(GND),
    .CLK(RGMII_GTXCLK_d) 
);
  ODDR \oddr_gen[2].oddr_inst  (
    .Q0(RGMII_TXD_d[2]),
    .Q1(\oddr_gen[2].oddr_inst_1_Q1 ),
    .D0(gmii_txd_r[2]),
    .D1(gmii_txd_r[6]),
    .TX(GND),
    .CLK(RGMII_GTXCLK_d) 
);
  ODDR \oddr_gen[3].oddr_inst  (
    .Q0(RGMII_TXD_d[3]),
    .Q1(\oddr_gen[3].oddr_inst_1_Q1 ),
    .D0(gmii_txd_r[3]),
    .D1(gmii_txd_r[7]),
    .TX(GND),
    .CLK(RGMII_GTXCLK_d) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* GMII2RGMII */
