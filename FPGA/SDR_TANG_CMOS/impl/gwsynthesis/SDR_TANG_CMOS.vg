`pragma protect end_protected
module fifo_tx (
  tx_data_valid,
  u_rf_rxt_4_4,
  u_rf_data_processor_2_6,
  tx_data_in,
  u_rf_rxt_0,
  u_rf_rxt_1,
  tx_fifo_full,
  empty_flag
)
;
input tx_data_valid;
input u_rf_rxt_4_4;
input u_rf_data_processor_2_6;
input [7:0] tx_data_in;
output u_rf_rxt_0;
output u_rf_rxt_1;
output tx_fifo_full;
