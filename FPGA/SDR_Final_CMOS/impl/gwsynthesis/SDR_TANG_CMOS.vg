  rx_data_out,
  rx_data_missing,
  rx_fifo_empty
)
;
input demod_valid;
input rx_clk_out;
input u_rf_rxt_5_4;
input u_rf_rxt_7_1;
input u_rf_rxt_8_1;
output rx_data_out;
output rx_data_missing;
output rx_fifo_empty;
wire VCC;
wire GND;
  \~fifo.fifo_rx  fifo_inst (
    .demod_valid(demod_valid),
    .rx_clk_out(rx_clk_out),
    .u_rf_rxt_5_4(u_rf_rxt_5_4),
    .u_rf_rxt_7_1(u_rf_rxt_7_1),
    .u_rf_rxt_8_1(u_rf_rxt_8_1),
    .rx_data_out(rx_data_out),
    .rx_data_missing(rx_data_missing),
    .rx_fifo_empty(rx_fifo_empty)
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_rx */
