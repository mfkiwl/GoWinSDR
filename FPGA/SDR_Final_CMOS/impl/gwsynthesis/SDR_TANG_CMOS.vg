`pragma protect end_protected
module fifo_rx (
  demod_valid,
  rx_clk_out,
  demod_bit_clk,
  u_rf_rxt_6_1,
  u_rf_rxt_7_1,
  rx_data_out,
  rx_data_missing,
  rx_fifo_empty
)
;
input demod_valid;
input rx_clk_out;
input demod_bit_clk;
input u_rf_rxt_6_1;
input u_rf_rxt_7_1;
output rx_data_out;
output rx_data_missing;
output rx_fifo_empty;
wire VCC;
wire GND;
  \~fifo.fifo_rx  fifo_inst (
    .demod_valid(demod_valid),
    .rx_clk_out(rx_clk_out),
    .demod_bit_clk(demod_bit_clk),
    .u_rf_rxt_6_1(u_rf_rxt_6_1),
    .u_rf_rxt_7_1(u_rf_rxt_7_1),
    .rx_data_out(rx_data_out),
    .rx_data_missing(rx_data_missing),
    .rx_fifo_empty(rx_fifo_empty)
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_rx */
module qpsk_differential_decoder (
  demod_bit_clk,
  n168_6,
  demod_valid,
  u_rf_rxt_3_2,
  u_rf_rxt_2_2,
  u_rf_rxt_7_1,
  u_rf_rxt_6_1
)
;
input demod_bit_clk;
input n168_6;
input demod_valid;
input u_rf_rxt_3_2;
input u_rf_rxt_2_2;
output u_rf_rxt_7_1;
output u_rf_rxt_6_1;
wire n7_3;
wire n8_3;
wire i_prev;
wire q_prev;
wire VCC;
wire GND;
  LUT2 n7_s0 (
    .F(n7_3),
    .I0(u_rf_rxt_3_2),
    .I1(i_prev) 
);
defparam n7_s0.INIT=4'h6;
  LUT2 n8_s0 (
    .F(n8_3),
    .I0(u_rf_rxt_2_2),
    .I1(q_prev) 
);
defparam n8_s0.INIT=4'h6;
  DFFCE data_out_0_s0 (
    .Q(u_rf_rxt_7_1),
    .D(n7_3),
    .CLK(demod_bit_clk),
    .CLEAR(n168_6),
    .CE(demod_valid) 
);
  DFFCE i_prev_s0 (
    .Q(i_prev),
    .D(u_rf_rxt_3_2),
    .CLK(demod_bit_clk),
    .CLEAR(n168_6),
    .CE(demod_valid) 
);
  DFFCE q_prev_s0 (
    .Q(q_prev),
    .D(u_rf_rxt_2_2),
    .CLK(demod_bit_clk),
    .CLEAR(n168_6),
    .CE(demod_valid) 
);
  DFFCE data_out_1_s0 (
    .Q(u_rf_rxt_6_1),
    .D(n8_3),
    .CLK(demod_bit_clk),
    .CLEAR(n168_6),
    .CE(demod_valid) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* qpsk_differential_decoder */
module rf_rxt (
  tx_clk_out_p_d,
  n168_6,
  trig_out_d,
