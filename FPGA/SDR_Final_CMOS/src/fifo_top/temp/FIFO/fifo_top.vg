`pragma protect end_protected
module fifo_tx (
  Data,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Q,
  Empty,
  Full
)
;
input [7:0] Data;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [1:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.fifo_tx  fifo_inst (
    .RdClk(RdClk),
    .WrClk(WrClk),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[7:0]),
    .Full(Full),
    .Empty(Empty),
    .Q(Q[1:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* fifo_tx */
