`pragma protect end_protected
module fifo_rx (
  demod_valid,
  clk_250k_reg,
  u_rf_rxt_5_4,
  u_rf_rxt_3_2,
  u_rf_rxt_2_2,
  rx_data_out,
  rx_data_missing,
  rx_fifo_empty
)
;
input demod_valid;
input clk_250k_reg;
input u_rf_rxt_5_4;
input u_rf_rxt_3_2;
input u_rf_rxt_2_2;
output rx_data_out;
output rx_data_missing;
output rx_fifo_empty;
wire VCC;
wire GND;
