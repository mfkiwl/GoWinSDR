    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_tx */
module qpsk_differential_encoder (
  rx_clk_out,
  n168_6,
  n328_8,
  qpsk_idle_flag,
  u_rf_rxt_0,
  tx_encoder_valid,
  tx_data_iq_diff
)
;
input rx_clk_out;
input n168_6;
input n328_8;
input qpsk_idle_flag;
input u_rf_rxt_0;
output tx_encoder_valid;
output [1:1] tx_data_iq_diff;
wire n15_3;
wire n20_5;
wire n8_9;
wire last_data_valid;
wire i_prev;
wire VCC;
wire GND;
  LUT3 n15_s0 (
    .F(n15_3),
    .I0(qpsk_idle_flag),
    .I1(u_rf_rxt_0),
    .I2(i_prev) 
);
defparam n15_s0.INIT=8'hB4;
  LUT2 q_out_s3 (
    .F(n20_5),
    .I0(last_data_valid),
    .I1(qpsk_idle_flag) 
);
defparam q_out_s3.INIT=4'hB;
  LUT3 n8_s2 (
    .F(n8_9),
    .I0(qpsk_idle_flag),
    .I1(u_rf_rxt_0),
    .I2(i_prev) 
);
defparam n8_s2.INIT=8'hB4;
  DFFCE out_valid_s0 (
    .Q(tx_encoder_valid),
    .D(n20_5),
    .CLK(rx_clk_out),
    .CLEAR(n168_6),
    .CE(VCC) 
);
  DFFCE last_data_valid_s0 (
    .Q(last_data_valid),
    .D(n328_8),
    .CLK(rx_clk_out),
    .CLEAR(n168_6),
    .CE(VCC) 
);
  DFFCE q_out_s1 (
    .Q(tx_data_iq_diff[1]),
    .D(n15_3),
    .CLK(rx_clk_out),
    .CLEAR(n168_6),
    .CE(n20_5) 
);
defparam q_out_s1.INIT=1'b0;
  DFFCE i_prev_s2 (
    .Q(i_prev),
    .D(n8_9),
    .CLK(rx_clk_out),
    .CLEAR(n168_6),
    .CE(VCC) 
);
defparam i_prev_s2.INIT=1'b0;
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* qpsk_differential_encoder */
