  tx_data_ready_Z_4,
  u_rf_rxt_0,
  u_rf_rxt_1,
  u_rf_rxt_2_2,
  u_rf_rxt_3_2,
  u_rf_rxt_4_4,
  u_rf_rxt_5_4,
  u_rf_data_processor_2_6,
  eth_rx_frame_start,
  eth_rx_frame_end,
  eth_rx_data_valid,
  u_rf_data_processor_0_4,
  u_rf_data_processor_1_4,
  rx_data_in_d,
  adc_data_out_i1,
  adc_data_out_q1,
  dac_data_in_i1_3,
  dac_data_in_i1_10,
  dac_data_in_i1_11,
  dac_data_in_q1,
  rx_data_out,
  tx_data_in,
  eth_rx_data,
  tdo_pad_o
)
;
input tms_pad_i;
input tck_pad_i;
input tdi_pad_i;
input tx_clk_out_p_d;
input RGMII_RST_N_d;
input rx_data_valid_Z_4;
input rx_data_missing;
input tx_data_valid;
input tx_data_ready_Z_4;
input u_rf_rxt_0;
input u_rf_rxt_1;
input u_rf_rxt_2_2;
input u_rf_rxt_3_2;
input u_rf_rxt_4_4;
input u_rf_rxt_5_4;
input u_rf_data_processor_2_6;
input eth_rx_frame_start;
input eth_rx_frame_end;
input eth_rx_data_valid;
input u_rf_data_processor_0_4;
input u_rf_data_processor_1_4;
input [11:0] rx_data_in_d;
