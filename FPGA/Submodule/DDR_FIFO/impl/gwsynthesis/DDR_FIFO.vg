module Gowin_PLL_MOD (
  sys_clk_d,
  rRstOut,
  rMdInc,
  rMdOpc,
  rMdDOut,
  pll_lock,
  clk100M,
  memory_clk,
  wMdQOut
)
;
input sys_clk_d;
input rRstOut;
input rMdInc;
input [1:0] rMdOpc;
input [7:0] rMdDOut;
output pll_lock;
output clk100M;
output memory_clk;
output [7:0] wMdQOut;
wire clkout0;
wire clkout3;
wire clkout4;
wire clkout5;
wire clkout6;
wire clkfbout;
wire VCC;
wire GND;
  PLLA PLLA_inst (
    .MDRDO(wMdQOut[7:0]),
    .LOCK(pll_lock),
    .CLKOUT0(clkout0),
    .CLKOUT1(clk100M),
    .CLKOUT2(memory_clk),
    .CLKOUT3(clkout3),
    .CLKOUT4(clkout4),
    .CLKOUT5(clkout5),
    .CLKOUT6(clkout6),
    .CLKFBOUT(clkfbout),
    .CLKIN(sys_clk_d),
    .CLKFB(GND),
    .RESET(rRstOut),
    .PLLPWD(GND),
    .RESET_I(GND),
    .RESET_O(GND),
    .PSSEL({GND,GND,GND}),
