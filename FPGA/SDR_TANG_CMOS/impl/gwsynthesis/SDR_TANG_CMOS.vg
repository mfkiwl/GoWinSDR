input dac_data_in_i1_10;
input dac_data_in_i1_11;
input [11:10] dac_data_in_q1;
input [7:0] rx_data_out;
input [7:0] tx_data_in;
input [7:0] eth_rx_data;
output tdo_pad_o;
wire tms_i_c;
wire tck_i_c;
wire tdi_i_c;
wire tdo_o_c;
wire gao_jtag_tdi;
wire gao_jtag_reset;
wire run_test_idle_er1;
wire run_test_idle_er2;
wire shift_dr_capture_dr;
wire pause_dr;
wire enable_er1;
wire enable_er2;
wire tdo_er1;
wire n12_6;
wire [5:0] control0;
wire [4:2] control0_0;
wire [3:0] module_id_reg;
wire [7:7] control0_1;
wire VCC;
wire GND;
  IBUF tms_ibuf (
    .O(tms_i_c),
    .I(tms_pad_i) 
);
  IBUF tck_ibuf (
    .O(tck_i_c),
    .I(tck_pad_i) 
);
  IBUF tdi_ibuf (
    .O(tdi_i_c),
    .I(tdi_pad_i) 
);
  OBUF tdo_obuf (
    .O(tdo_pad_o),
    .I(tdo_o_c) 
);
//black box: GW_JTAG u_gw_jtag
  GW_JTAG u_gw_jtag (
    .tck_pad_i(tck_i_c),
    .tms_pad_i(tms_i_c),
    .tdi_pad_i(tdi_i_c),
    .tdo_er1_i(tdo_er1),
    .tdo_er2_i(GND),
    .tdo_pad_o(tdo_o_c),
    .tck_o(control0[0]),
