input n82_6;
input demod_valid;
input u_rf_rxt_27_2;
input u_rf_rxt_26_2;
output u_rf_rxt_32_1;
output u_rf_rxt_31_1;
wire n7_3;
wire n8_3;
wire i_prev;
wire q_prev;
wire VCC;
wire GND;
  LUT2 n7_s0 (
    .F(n7_3),
    .I0(u_rf_rxt_27_2),
    .I1(i_prev) 
);
defparam n7_s0.INIT=4'h6;
  LUT2 n8_s0 (
    .F(n8_3),
    .I0(u_rf_rxt_26_2),
    .I1(q_prev) 
);
defparam n8_s0.INIT=4'h6;
  DFFCE data_out_0_s0 (
    .Q(u_rf_rxt_32_1),
    .D(n7_3),
    .CLK(u_rf_rxt_29_4),
    .CLEAR(n82_6),
    .CE(demod_valid) 
);
  DFFCE i_prev_s0 (
    .Q(i_prev),
    .D(u_rf_rxt_27_2),
    .CLK(u_rf_rxt_29_4),
    .CLEAR(n82_6),
    .CE(demod_valid) 
);
  DFFCE q_prev_s0 (
    .Q(q_prev),
    .D(u_rf_rxt_26_2),
    .CLK(u_rf_rxt_29_4),
    .CLEAR(n82_6),
    .CE(demod_valid) 
);
  DFFCE data_out_1_s0 (
    .Q(u_rf_rxt_31_1),
    .D(n8_3),
    .CLK(u_rf_rxt_29_4),
    .CLEAR(n82_6),
    .CE(demod_valid) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* qpsk_differential_decoder */
