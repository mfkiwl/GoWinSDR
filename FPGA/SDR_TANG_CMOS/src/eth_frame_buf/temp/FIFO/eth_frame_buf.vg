`pragma protect end_protected
module eth_frame_buf (
  Data,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Q,
  Empty,
  Full
)
;
input [7:0] Data;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [7:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.eth_frame_buf  fifo_inst (
    .RdClk(RdClk),
    .WrClk(WrClk),
    .RdEn(RdEn),
    .WrEn(WrEn),
    .Data(Data[7:0]),
    .Full(Full),
    .Empty(Empty),
    .Q(Q[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* eth_frame_buf */
