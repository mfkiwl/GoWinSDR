`pragma protect end_protected
module fifo_tx (
  trig_out_d,
  u_rf_rxt_4_4,
  u_rf_data_processor_2_6,
  tx_data_in,
  empty_flag,
  u_rf_rxt_0
)
;
input trig_out_d;
input u_rf_rxt_4_4;
input u_rf_data_processor_2_6;
input [7:0] tx_data_in;
output empty_flag;
output u_rf_rxt_0;
wire VCC;
wire GND;
  \~fifo.fifo_tx  fifo_inst (
    .trig_out_d(trig_out_d),
    .u_rf_rxt_4_4(u_rf_rxt_4_4),
    .u_rf_data_processor_2_6(u_rf_data_processor_2_6),
    .tx_data_in(tx_data_in[7:0]),
    .empty_flag(empty_flag),
    .u_rf_rxt_0(u_rf_rxt_0)
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_tx */
module qpsk_differential_encoder (
  u_rf_rxt_4_4,
  n12_6,
  n292_8,
  qpsk_idle_flag,
  u_rf_rxt_0,
  tx_encoder_valid,
  tx_data_iq_diff
)
;
input u_rf_rxt_4_4;
input n12_6;
input n292_8;
input qpsk_idle_flag;
input u_rf_rxt_0;
output tx_encoder_valid;
output [1:1] tx_data_iq_diff;
wire n15_3;
wire n20_5;
wire n8_9;
wire last_data_valid;
wire i_prev;
wire VCC;
wire GND;
  LUT3 n15_s0 (
    .F(n15_3),
    .I0(qpsk_idle_flag),
    .I1(u_rf_rxt_0),
    .I2(i_prev) 
);
defparam n15_s0.INIT=8'hB4;
  LUT2 q_out_s3 (
    .F(n20_5),
    .I0(last_data_valid),
    .I1(qpsk_idle_flag) 
);
defparam q_out_s3.INIT=4'hB;
  LUT3 n8_s2 (
    .F(n8_9),
    .I0(qpsk_idle_flag),
    .I1(u_rf_rxt_0),
    .I2(i_prev) 
);
defparam n8_s2.INIT=8'hB4;
  DFFCE out_valid_s0 (
    .Q(tx_encoder_valid),
    .D(n20_5),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE last_data_valid_s0 (
    .Q(last_data_valid),
    .D(n292_8),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE q_out_s1 (
    .Q(tx_data_iq_diff[1]),
    .D(n15_3),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n12_6),
    .CE(n20_5) 
);
defparam q_out_s1.INIT=1'b0;
  DFFCE i_prev_s2 (
    .Q(i_prev),
    .D(n8_9),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n12_6),
    .CE(VCC) 
);
defparam i_prev_s2.INIT=1'b0;
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* qpsk_differential_encoder */
module qpsk_differential_decoder (
  rx_clk_out,
  n12_6,
  demod_valid,
  u_rf_rxt_1_2,
  rx_data_out,
  rx_data_valid
)
;
input rx_clk_out;
input n12_6;
input demod_valid;
input u_rf_rxt_1_2;
output rx_data_out;
output rx_data_valid;
wire n7_3;
wire i_prev;
wire VCC;
wire GND;
  LUT2 n7_s0 (
    .F(n7_3),
    .I0(u_rf_rxt_1_2),
    .I1(i_prev) 
);
defparam n7_s0.INIT=4'h6;
  DFFCE data_out_0_s0 (
    .Q(rx_data_out),
    .D(n7_3),
    .CLK(rx_clk_out),
    .CLEAR(n12_6),
    .CE(demod_valid) 
);
  DFFCE i_prev_s0 (
    .Q(i_prev),
    .D(u_rf_rxt_1_2),
    .CLK(rx_clk_out),
    .CLEAR(n12_6),
    .CE(demod_valid) 
);
  DFFCE out_valid_s0 (
    .Q(rx_data_valid),
    .D(demod_valid),
    .CLK(rx_clk_out),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* qpsk_differential_decoder */
module rf_rxt (
  tx_clk_out_p_d,
  trig_out_d,
  u_rf_data_processor_2_6,
  RGMII_RST_N_d,
  adc_data_out_i1,
  tx_data_in,
  u_rf_rxt_5_2,
  u_rf_rxt_6_2,
  u_rf_rxt_13_2,
  u_rf_rxt_1_2,
  u_rf_rxt_4_4,
  rx_clk_out,
  rx_data_out,
  rx_data_valid,
  u_rf_rxt_0,
  n12_6,
  dac_data_in_i1,
  dac_data_in_q1
)
;
input tx_clk_out_p_d;
input trig_out_d;
input u_rf_data_processor_2_6;
input RGMII_RST_N_d;
input [11:11] adc_data_out_i1;
input [7:0] tx_data_in;
output u_rf_rxt_5_2;
output u_rf_rxt_6_2;
output u_rf_rxt_13_2;
output u_rf_rxt_1_2;
output u_rf_rxt_4_4;
output rx_clk_out;
output rx_data_out;
output rx_data_valid;
output u_rf_rxt_0;
output n12_6;
output [11:0] dac_data_in_i1;
output [11:0] dac_data_in_q1;
wire n196_6;
wire n185_6;
wire n184_6;
wire n365_7;
wire n364_7;
wire n177_6;
wire n97_7;
wire n96_7;
wire n366_11;
wire n98_11;
wire qpsk_idle_flag_reg;
wire qpsk_valid;
wire demod_valid;
wire qpsk_idle_flag;
wire n141_6;
wire n719_5;
wire n292_8;
wire empty_flag;
wire tx_encoder_valid;
wire [1:0] bit_counter;
wire [11:11] qpsk_i;
wire [10:10] qpsk_q;
wire [11:11] qpsk_q_reg;
wire [1:0] demod_bit_counter;
wire [11:11] demod_i;
wire [1:1] tx_data_iq_diff;
wire VCC;
wire GND;
  LUT2 n196_s1 (
    .F(n196_6),
    .I0(tx_encoder_valid),
    .I1(qpsk_i[11]) 
);
defparam n196_s1.INIT=4'h8;
  LUT2 n185_s1 (
    .F(n185_6),
    .I0(tx_encoder_valid),
    .I1(qpsk_q[10]) 
);
defparam n185_s1.INIT=4'h8;
  LUT2 n184_s1 (
    .F(n184_6),
    .I0(tx_encoder_valid),
    .I1(qpsk_i[11]) 
);
defparam n184_s1.INIT=4'h8;
  LUT2 n365_s2 (
    .F(n365_7),
    .I0(demod_bit_counter[0]),
    .I1(demod_bit_counter[1]) 
);
defparam n365_s2.INIT=4'h1;
  LUT2 n364_s2 (
    .F(n364_7),
    .I0(demod_bit_counter[1]),
    .I1(demod_bit_counter[0]) 
);
defparam n364_s2.INIT=4'h4;
  LUT2 n177_s1 (
    .F(n177_6),
    .I0(empty_flag),
    .I1(qpsk_idle_flag_reg) 
);
defparam n177_s1.INIT=4'h8;
  LUT2 n97_s2 (
    .F(n97_7),
    .I0(bit_counter[0]),
    .I1(bit_counter[1]) 
);
defparam n97_s2.INIT=4'h1;
  LUT2 n96_s2 (
    .F(n96_7),
    .I0(bit_counter[1]),
    .I1(bit_counter[0]) 
);
defparam n96_s2.INIT=4'h4;
  LUT2 n366_s5 (
    .F(n366_11),
    .I0(rx_clk_out),
    .I1(demod_bit_counter[1]) 
);
defparam n366_s5.INIT=4'h6;
  LUT2 n98_s5 (
    .F(n98_11),
    .I0(u_rf_rxt_4_4),
    .I1(bit_counter[1]) 
);
defparam n98_s5.INIT=4'h6;
  DFFCE bit_counter_1_s0 (
    .Q(bit_counter[1]),
    .D(n96_7),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE bit_counter_0_s0 (
    .Q(bit_counter[0]),
    .D(n97_7),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE qpsk_i_11_s0 (
    .Q(qpsk_i[11]),
    .D(n141_6),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(GND),
    .CE(VCC) 
);
  DFFCE qpsk_q_10_s0 (
    .Q(qpsk_q[10]),
    .D(tx_data_iq_diff[1]),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(GND),
    .CE(VCC) 
);
  DFFPE qpsk_idle_flag_reg_s0 (
    .Q(qpsk_idle_flag_reg),
    .D(empty_flag),
    .CLK(u_rf_rxt_4_4),
    .PRESET(n12_6),
    .CE(VCC) 
);
  DFFCE qpsk_i_reg_11_s0 (
    .Q(u_rf_rxt_5_2),
    .D(n184_6),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE qpsk_i_reg_10_s0 (
    .Q(u_rf_rxt_6_2),
    .D(n185_6),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE qpsk_i_reg_3_s0 (
    .Q(u_rf_rxt_13_2),
    .D(tx_encoder_valid),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE qpsk_q_reg_11_s0 (
    .Q(qpsk_q_reg[11]),
    .D(n196_6),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE qpsk_valid_s0 (
    .Q(qpsk_valid),
    .D(VCC),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE demod_bit_counter_1_s0 (
    .Q(demod_bit_counter[1]),
    .D(n364_7),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE demod_bit_counter_0_s0 (
    .Q(demod_bit_counter[0]),
    .D(n365_7),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE demod_i_11_s0 (
    .Q(demod_i[11]),
    .D(adc_data_out_i1[11]),
    .CLK(rx_clk_out),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE demod_data_s0 (
    .Q(u_rf_rxt_1_2),
    .D(n719_5),
    .CLK(rx_clk_out),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFCE demod_valid_s0 (
    .Q(demod_valid),
    .D(VCC),
    .CLK(rx_clk_out),
    .CLEAR(n12_6),
    .CE(VCC) 
);
  DFFPE qpsk_idle_flag_s0 (
    .Q(qpsk_idle_flag),
    .D(n177_6),
    .CLK(u_rf_rxt_4_4),
    .PRESET(n12_6),
    .CE(VCC) 
);
  DFFCE bit_clk_s2 (
    .Q(u_rf_rxt_4_4),
    .D(n98_11),
    .CLK(tx_clk_out_p_d),
    .CLEAR(n12_6),
    .CE(VCC) 
);
defparam bit_clk_s2.INIT=1'b0;
