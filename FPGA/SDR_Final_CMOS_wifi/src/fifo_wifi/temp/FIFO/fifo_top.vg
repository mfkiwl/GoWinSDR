module fifo_wifi (
  Data,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Almost_Full,
  Q,
  Empty,
  Full
)
;
input [7:0] Data;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output Almost_Full;
output [31:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.fifo_wifi  fifo_inst (
    .RdClk(RdClk),
    .WrClk(WrClk),
    .RdEn(RdEn),
    .WrEn(WrEn),
    .Data(Data[7:0]),
    .Full(Full),
    .Almost_Full(Almost_Full),
    .Empty(Empty),
    .Q(Q[31:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* fifo_wifi */
