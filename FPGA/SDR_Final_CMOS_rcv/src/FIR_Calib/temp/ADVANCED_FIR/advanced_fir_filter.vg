`pragma protect end_protected
module FIR_Calib (
  clk,
  rstn,
  fir_rfi_o,
  fir_valid_i,
  fir_sync_i,
  fir_data_i,
  fir_valid_o,
  fir_sync_o,
  fir_data_o
)
;
input clk;
input rstn;
output fir_rfi_o;
input fir_valid_i;
input fir_sync_i;
input [11:0] fir_data_i;
output fir_valid_o;
output fir_sync_o;
output [11:0] fir_data_o;
wire VCC;
wire GND;
  \advanced_fir_filter/FIR_Calib  advanced_fir_filter_inst (
    .clk(clk),
    .fir_valid_i(fir_valid_i),
    .fir_sync_i(fir_sync_i),
    .rstn(rstn),
    .fir_data_i(fir_data_i[11:0]),
    .fir_valid_o(fir_valid_o),
    .fir_rfi_o(fir_rfi_o),
    .fir_data_o(fir_data_o[11:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
assign fir_sync_o = fir_valid_o;
endmodule /* FIR_Calib */
