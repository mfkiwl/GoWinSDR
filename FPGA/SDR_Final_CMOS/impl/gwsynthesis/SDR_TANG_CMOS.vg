`pragma protect end_protected
module fifo_tx (
  tx_data_valid,
  u_rf_rxt_4_4,
  u_rf_data_processor_2_6,
  tx_data_in,
  u_rf_rxt_0,
  u_rf_rxt_1,
  empty_flag
)
;
input tx_data_valid;
input u_rf_rxt_4_4;
input u_rf_data_processor_2_6;
input [7:0] tx_data_in;
output u_rf_rxt_0;
output u_rf_rxt_1;
output empty_flag;
wire VCC;
wire GND;
  \~fifo.fifo_tx  fifo_inst (
    .tx_data_valid(tx_data_valid),
    .u_rf_rxt_4_4(u_rf_rxt_4_4),
    .u_rf_data_processor_2_6(u_rf_data_processor_2_6),
    .tx_data_in(tx_data_in[7:0]),
    .u_rf_rxt_0(u_rf_rxt_0),
    .u_rf_rxt_1(u_rf_rxt_1),
    .empty_flag(empty_flag)
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_tx */
module qpsk_differential_encoder (
  u_rf_rxt_4_4,
  n167_6,
  n433_9,
  u_rf_rxt_1,
  qpsk_idle_flag,
  u_rf_rxt_0,
  tx_encoder_valid,
  tx_data_iq_diff
)
;
input u_rf_rxt_4_4;
input n167_6;
input n433_9;
input u_rf_rxt_1;
input qpsk_idle_flag;
input u_rf_rxt_0;
output tx_encoder_valid;
output [1:0] tx_data_iq_diff;
wire n15_3;
wire n16_3;
wire n21_5;
wire n7_9;
wire n8_6;
wire last_data_valid;
wire i_prev;
wire q_prev;
wire VCC;
wire GND;
  LUT3 n15_s0 (
    .F(n15_3),
    .I0(u_rf_rxt_1),
    .I1(qpsk_idle_flag),
    .I2(i_prev) 
);
defparam n15_s0.INIT=8'h1E;
  LUT3 n16_s0 (
    .F(n16_3),
    .I0(qpsk_idle_flag),
    .I1(u_rf_rxt_0),
    .I2(q_prev) 
);
defparam n16_s0.INIT=8'hB4;
  LUT2 q_out_s3 (
    .F(n21_5),
    .I0(last_data_valid),
    .I1(qpsk_idle_flag) 
);
defparam q_out_s3.INIT=4'hB;
  LUT3 n7_s2 (
    .F(n7_9),
    .I0(qpsk_idle_flag),
    .I1(u_rf_rxt_1),
    .I2(i_prev) 
);
defparam n7_s2.INIT=8'hB4;
  LUT3 n8_s2 (
    .F(n8_6),
    .I0(qpsk_idle_flag),
    .I1(u_rf_rxt_0),
    .I2(q_prev) 
);
defparam n8_s2.INIT=8'hB4;
  DFFCE out_valid_s0 (
    .Q(tx_encoder_valid),
    .D(n21_5),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n167_6),
    .CE(VCC) 
);
  DFFCE last_data_valid_s0 (
    .Q(last_data_valid),
    .D(n433_9),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n167_6),
    .CE(VCC) 
);
  DFFCE q_out_s1 (
    .Q(tx_data_iq_diff[1]),
    .D(n16_3),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n167_6),
    .CE(n21_5) 
);
defparam q_out_s1.INIT=1'b0;
  DFFCE i_out_s1 (
    .Q(tx_data_iq_diff[0]),
    .D(n15_3),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n167_6),
    .CE(n21_5) 
);
defparam i_out_s1.INIT=1'b0;
  DFFCE i_prev_s2 (
    .Q(i_prev),
    .D(n7_9),
    .CLK(u_rf_rxt_4_4),
    .CLEAR(n167_6),
    .CE(VCC) 
);
defparam i_prev_s2.INIT=1'b0;
