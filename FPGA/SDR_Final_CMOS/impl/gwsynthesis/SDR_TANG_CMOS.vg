);
endmodule /* fifo_rx */
module qpsk_differential_decoder (
  u_rf_rxt_29_4,
  n82_6,
  demod_valid,
  u_rf_rxt_27_2,
  u_rf_rxt_26_2,
  u_rf_rxt_32_1,
  u_rf_rxt_31_1
)
;
