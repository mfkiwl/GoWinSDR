module gw_gao (
  tms_pad_i,
  tck_pad_i,
  tdi_pad_i,
  tx_clk_out_p_d,
  eth_rx_frame_end,
  eth_rx_data_valid,
  tx_data_valid_t2,
  fifo_empty_reg,
  rx_data_valid_d,
  tx_data_valid_r,
  wifi_frame_start,
  adc_data_out_i1,
  adc_data_out_q1,
  dac_data_in_i1,
  dac_data_in_q1,
  eth_rx_data,
  fifo_out,
  tdo_pad_o
)
;
input tms_pad_i;
input tck_pad_i;
input tdi_pad_i;
input tx_clk_out_p_d;
input eth_rx_frame_end;
input eth_rx_data_valid;
input tx_data_valid_t2;
input fifo_empty_reg;
input rx_data_valid_d;
input tx_data_valid_r;
input wifi_frame_start;
input [11:0] adc_data_out_i1;
input [11:0] adc_data_out_q1;
input [11:0] dac_data_in_i1;
input [11:0] dac_data_in_q1;
input [7:0] eth_rx_data;
input [31:0] fifo_out;
output tdo_pad_o;
wire tms_i_c;
wire tck_i_c;
wire tdi_i_c;
wire tdo_o_c;
wire gao_jtag_tdi;
wire gao_jtag_reset;
wire run_test_idle_er1;
wire run_test_idle_er2;
wire shift_dr_capture_dr;
wire pause_dr;
wire enable_er1;
wire enable_er2;
wire tdo_er1;
wire n12_6;
wire [5:0] control0;
wire [4:2] control0_0;
wire [3:0] module_id_reg;
wire [7:7] control0_1;
wire VCC;
wire GND;
  IBUF tms_ibuf (
    .O(tms_i_c),
    .I(tms_pad_i) 
);
  IBUF tck_ibuf (
    .O(tck_i_c),
    .I(tck_pad_i) 
);
  IBUF tdi_ibuf (
    .O(tdi_i_c),
    .I(tdi_pad_i) 
);
  OBUF tdo_obuf (
    .O(tdo_pad_o),
    .I(tdo_o_c) 
);
//black box: GW_JTAG u_gw_jtag
  GW_JTAG u_gw_jtag (
    .tck_pad_i(tck_i_c),
    .tms_pad_i(tms_i_c),
    .tdi_pad_i(tdi_i_c),
    .tdo_er1_i(tdo_er1),
    .tdo_er2_i(GND),
    .tdo_pad_o(tdo_o_c),
    .tck_o(control0[0]),
    .tdi_o(gao_jtag_tdi),
    .test_logic_reset_o(gao_jtag_reset),
    .run_test_idle_er1_o(run_test_idle_er1),
    .run_test_idle_er2_o(run_test_idle_er2),
    .shift_dr_capture_dr_o(shift_dr_capture_dr),
    .pause_dr_o(pause_dr),
    .update_dr_o(control0[5]),
    .enable_er1_o(enable_er1),
    .enable_er2_o(enable_er2) 
);
  gw_con_top u_icon_top (
    .shift_dr_capture_dr(shift_dr_capture_dr),
    .enable_er1(enable_er1),
    .gao_jtag_tdi(gao_jtag_tdi),
    .gao_jtag_reset(gao_jtag_reset),
    .control0(control0_1[7]),
    .control0_0_1(control0[0]),
    .control0_5(control0[5]),
    .tdo_er1(tdo_er1),
    .n12_6(n12_6),
    .control0_2_3(control0_0[2]),
    .control0_4(control0_0[4]),
    .module_id_reg(module_id_reg[3:0])
);
  ao_top_0 u_la0_top (
    .n12_6(n12_6),
    .tx_clk_out_p_d(tx_clk_out_p_d),
    .shift_dr_capture_dr(shift_dr_capture_dr),
    .eth_rx_frame_end(eth_rx_frame_end),
    .eth_rx_data_valid(eth_rx_data_valid),
    .tx_data_valid_t2(tx_data_valid_t2),
    .fifo_empty_reg(fifo_empty_reg),
    .rx_data_valid_d(rx_data_valid_d),
    .tx_data_valid_r(tx_data_valid_r),
    .wifi_frame_start(wifi_frame_start),
    .control0_2(control0_0[2]),
    .control0_4(control0_0[4]),
    .control0_0(control0[0]),
    .control0_5_6(control0[5]),
    .module_id_reg(module_id_reg[3:0]),
    .adc_data_out_i1(adc_data_out_i1[11:0]),
    .adc_data_out_q1(adc_data_out_q1[11:0]),
    .dac_data_in_i1(dac_data_in_i1[11:0]),
    .dac_data_in_q1(dac_data_in_q1[11:0]),
    .eth_rx_data(eth_rx_data[7:0]),
    .fifo_out(fifo_out[31:0]),
    .control0_7(control0_1[7])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* gw_gao */
