  tx_frame_start_reg,
  sys_clk_d,
  RGMII_RXD_d,
  tx_data_reg,
  RGMII_TXEN_d,
  eth_rx_data_valid,
  tx_buf_ready,
  n1771_6,
  n1568_6,
  RGMII_GTXCLK_d,
  eth_rx_data,
  RGMII_TXD_d
)
;
input RGMII_RXCLK_d;
