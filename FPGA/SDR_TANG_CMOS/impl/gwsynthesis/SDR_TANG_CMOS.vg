`pragma protect end_protected
module fifo_tx (
  u_rf_rxt_4_4,
  test_clk_reg,
  test_data_cnt,
  u_rf_rxt_0,
  u_rf_rxt_1,
  tx_fifo_full,
  empty_flag
)
;
input u_rf_rxt_4_4;
input test_clk_reg;
input [7:0] test_data_cnt;
output u_rf_rxt_0;
